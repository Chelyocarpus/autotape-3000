# Dependencies
node_modules/

# Build outputs
dist/
out/

# electron-vite temp config snapshot
electron.vite.config.*.mjs
!electron.vite.config.mjs

# Bundled ffmpeg binary (large binary; fetched by @ffmpeg-installer at install time)
resources/ffmpeg/

# Native loopback-capture helper: Rust build artifacts and the compiled binary
# copied into resources/ by `pnpm build:native` (see native/loopback-capture/)
native/loopback-capture/target/
resources/native/

# Logs
*.log
*.log.*
npm-debug.log*
pnpm-debug.log*

# Editor / OS
.DS_Store
Thumbs.db
.eslintcache

# TypeScript incremental build cache
*.tsbuildinfo

# Local env files
.env
.env.*
!.env.example

# electron-builder update config (generated)
dev-app-update.yml
/.github
/.claude
